# 复制为 .env.local 后填值。生产部署时设置环境变量。
# 详见 CLAUDE.md §十二

# ---- 飞书自建应用 ----
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxx

# ---- 工具自己的 Bitable（你新建一个，存 requirements / templates / 等） ----
FEISHU_BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxxx
FEISHU_BITABLE_TABLE_REQUIREMENTS=tblxxxxxxxxxx
FEISHU_BITABLE_TABLE_ASSET_ITEMS=tblxxxxxxxxxx
FEISHU_BITABLE_TABLE_TEMPLATES=tblxxxxxxxxxx
FEISHU_BITABLE_TABLE_COLLABORATORS=tblxxxxxxxxxx
FEISHU_BITABLE_TABLE_MEMBERS=tblxxxxxxxxxx
FEISHU_BITABLE_TABLE_STATUS_LOGS=tblxxxxxxxxxx

# ---- 设计需求收单表（设计部门提供，暂用：
#   https://arashivision.feishu.cn/share/base/form/shrcnKeoh8KTVG0ZE2O3tecD9Wd
#   待补充：从该表后台拿 app_token / table_id） ----
DESIGN_INTAKE_BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxxx
DESIGN_INTAKE_TABLE_ID=tblxxxxxxxxxx

# ---- 飞书云盘：自动生成需求 docx 的目标文件夹（创建草稿时调用）----
# 未配置时跳过 docx 生成，不影响草稿；拿法见 .env.local
FEISHU_DOC_FOLDER_TOKEN=xxxxxxxxxxxxxxxxx

# ---- 需求文档模板 URL（生成 docx 末尾贴这个链接，让设计去看示例图）----
REQUIREMENT_DOC_TEMPLATE_URL=https://arashivision.feishu.cn/docx/xxxxxxxxxxxxx

# ---- 设计提单表单 URL（v1 手动提单跳转目标）----
DESIGN_INTAKE_FORM_URL=https://arashivision.feishu.cn/share/base/form/shrxxxxxxxxxxx

# ---- 飞书群机器人 webhook ----
FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# ---- 飞书项目空间 URL（v1 仅用作跳转） ----
FEISHU_PROJECT_SPACE_URL=https://project.feishu.cn/your-space

# ---- 开发开关 ----
# bitable: 接真实飞书后端  mock: 进程内内存数据（开发期跑通流程用）
DATA_SOURCE=mock
NEXT_PUBLIC_APP_NAME=资源适配工作台
